<Window x:Class="Evernight_Sticker.Views.DisplayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Evernight_Sticker.Views"
        mc:Ignorable="d"
        ShowInTaskbar="False"
        Title="{Binding Title, Mode=TwoWay}" Height="{Binding Height, Mode=TwoWay}" Width="{Binding Width, Mode=TwoWay}"
        Left="{Binding Left, Mode=TwoWay}" Top="{Binding Top, Mode=TwoWay}"
        WindowStyle="None" MouseDown="Window_MouseDown"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True" Closing="Window_Closing" StateChanged="Window_StateChanged" SizeChanged="Window_SizeChanged">
    <Grid>
        <Image Margin="0" Source="{Binding CurrentFrame}">
            <Image.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Frame Interval">
                        <StackPanel Margin="0,0,-45,0" Orientation="Horizontal">
                            <Slider Value="{Binding FrameInterval}" Width="220" Minimum="50" Maximum="120" SmallChange="0.01" LargeChange="0.01" FontFamily="Arial" Margin="0,1,0,0"/>
                            <TextBox Text="{Binding FrameInterval}" Width="55" FontFamily="Arial" TextAlignment="Center" FontSize="14" Margin="7,0,0,0" Padding="2,1,0,0"/>
                            <TextBlock Text="ms" FontFamily="Arial" Margin="6,0,7,0" FontSize="14"/>
                            <Border BorderThickness="1" BorderBrush="Black" CornerRadius="3" Background="#FFDADADA">
                                <Button Content="Default" Name="FrameIntervaleDefault_button" Click="FrameIntervaleDefault_button_Click" Padding="8,1" BorderBrush="{x:Null}" FontFamily="Arial" />
                            </Border>
                        </StackPanel>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Name="Close_button" Header="Close" Click="Close_button_Click" />
                </ContextMenu>
            </Image.ContextMenu>
        </Image>
    </Grid>
</Window>
