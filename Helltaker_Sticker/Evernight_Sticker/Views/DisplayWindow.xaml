<Window x:Class="Evernight_Sticker.Views.DisplayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Evernight_Sticker.Views"
        xmlns:gif="https://github.com/XamlAnimatedGif/XamlAnimatedGif"
        mc:Ignorable="d"
        ShowInTaskbar="False"
        Title="{Binding Title, Mode=TwoWay}" Height="{Binding Height}" Width="{Binding Width}"
        WindowStyle="None" MouseDown="Window_MouseDown"
        ResizeMode="CanResize"
        Topmost="True" Closing="Window_Closing" StateChanged="Window_StateChanged" SizeChanged="Window_SizeChanged" MouseUp="Window_MouseUp">
        <!--AllowsTransparency="True"
        Background="Transparent"-->
    <Grid>
        <Image gif:AnimationBehavior.SourceUri="{Binding FilePath}"/>
    </Grid>
</Window>
